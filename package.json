{
  "name": "frontend-realms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "tsx scripts/migrate-database.ts",
    "audit:production": "node scripts/production-audit.mjs",
    "audit:dependencies": "npm audit --audit-level=high",
    "depcruise": "depcruise --config .dependency-cruiser.cjs src --output-type err-long",
    "verify": "npm run format:check && npm run lint && npm run type-check && npm run depcruise && npm run audit:production && npm run audit:dependencies && npm run build",
    "verify:full": "npm run verify && npm run test",
    "docker:build": "docker build -t frontend-realms .",
    "docker:run": "docker run --rm -p 3000:3000 frontend-realms",
    "docker:verify": "node scripts/verify-docker-image.mjs",
    "fly:validate": "fly config validate",
    "fly:deploy": "fly deploy",
    "fly:status": "fly status",
    "fly:logs": "fly logs"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@hcaptcha/react-hcaptcha": "^2.0.2",
    "bcryptjs": "^3.0.3",
    "js-yaml": "^4.2.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "^4.22.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "better-sqlite3": "^12.11.1",
    "dependency-cruiser": "^17.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
